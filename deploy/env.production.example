# PROD-.env für Die Hand auf dem Server. Kopieren nach /var/lib/deploy/hand/.env
# und Werte setzen. NICHT committen (liegt nur auf dem Server).

# ── Auth (Google-OAuth) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=<twitterforfriends client id>
GOOGLE_CLIENT_SECRET=<twitterforfriends client secret>
# WICHTIG: muss die PROD-Domain sein und im Google-Client als Redirect-URI stehen:
OAUTH_REDIRECT_URI=https://hand.jeremias-groehl.de/auth/callback
SESSION_SECRET=<langes Zufallsgeheimnis, z.B. `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`>
ADMIN_EMAILS=fuumax2.0@gmail.com

# ── Port (hinter nginx) ──────────────────────────────────────────────
PORT=3737

# ── OrientDB ─────────────────────────────────────────────────────────
# Auf dem Prod-Server läuft OrientDB i.d.R. lokal/im compose -> direkt erreichbar,
# KEIN SSH-Tunnel nötig (SSH_HOST leer lassen).
ORIENTDB_URL=http://localhost:2480
ORIENTDB_USER=root
ORIENTDB_PASS=<orientdb root pw>
ORIENTDB_DB=auge

# ── gehirn (KI-API) ──────────────────────────────────────────────────
GEHIRN_URL=http://localhost:4000

# ── SSH-Tunnel (auf Prod normalerweise NICHT nötig) ──────────────────
SSH_HOST=
