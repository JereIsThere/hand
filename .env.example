# OrientDB-Verbindung (wenn SSH-Tunnel benutzt wird, zeigt diese URL auf das lokale Tunnel-Ende)
ORIENTDB_URL=http://localhost:2480
ORIENTDB_USER=root
ORIENTDB_PASS=changeme
ORIENTDB_DB=mydb

# Lokaler Admin-Port (Browser → hier)
PORT=3737

# ── SSH-Tunnel (optional) ──────────────────────────────────────────────
# Wenn SSH_HOST gesetzt ist, startet der Server vorher selbst
#   ssh -N -L <SSH_LOCAL_PORT>:<SSH_REMOTE_HOST>:<SSH_REMOTE_PORT> <SSH_USER>@<SSH_HOST>
# und beendet sich, wenn der Tunnel kippt. Voraussetzung: SSH-Key liegt
# beim Ziel-User (BatchMode=yes — kein Passwort-Prompt).
# Leer lassen wenn du den Tunnel selbst aufmachst oder OrientDB lokal läuft.
SSH_HOST=
SSH_USER=deploy
SSH_PORT=22
SSH_LOCAL_PORT=2480
SSH_REMOTE_HOST=localhost
SSH_REMOTE_PORT=2480
