# OrientDB-Verbindung (wenn SSH-Tunnel benutzt wird, zeigt diese URL auf das lokale Tunnel-Ende)
ORIENTDB_URL=http://localhost:2480
ORIENTDB_USER=root
ORIENTDB_PASS=changeme
ORIENTDB_DB=mydb

# Lokaler Admin-Port (Browser → hier)
PORT=3737

# ── Auth (Google-OAuth, optional) ──────────────────────────────────────
# Leer lassen -> Auth AUS, hand läuft lokal-offen als Single-Operator (wie bisher).
# Alle drei gesetzt -> Google-Login + Approval-Flow (Login → pending → Admin gibt frei).
# Google-OAuth-Client in der Google Cloud Console anlegen (Web application),
# Redirect-URI = <basis>/auth/callback eintragen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Muss zur in Google hinterlegten Redirect-URI passen:
OAUTH_REDIRECT_URI=http://localhost:3737/auth/callback
# Zufälliges langes Geheimnis zum Signieren der Session-Cookies:
SESSION_SECRET=
# Komma-Liste der Admin-Mails (= arm). Diese werden beim Login auto-freigegeben.
ADMIN_EMAILS=fuumax2.0@gmail.com

# ── AI Shell ─────────────────────────────────────────────────────────
# Wird von shell-ai.mjs fuer Haiku-Analyse genutzt.
# Auch von sprecher (Chat) verwendet wenn er dazukommt.
ANTHROPIC_API_KEY=

# ── Vault ──────────────────────────────────────────────────────────────
# Pflicht damit der Vault aktiv ist. 32-Byte-Key als Hex (64 Zeichen):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_KEY=

# ── KI für sprecher (direkt in hand; besser im Vault/Setup setzen) ─────
ANTHROPIC_API_KEY=
GROK_API_KEY=
ATLASCLOUD_API_KEY=       # atlascloud.ai — Flux, Imagen, Ideogram, Seedream, Z-Image

# ── Capture (Auge-App → POST /api/capture) ────────────────────────────
# Bearer-Token für den Capture-Endpoint (Funkner-Sync der Auge-App).
# Leer lassen -> Endpoint antwortet 503 (Feature aus). Generieren:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CAPTURE_API_KEY=

# ── GitHub-Build (Submission → meta.ts-Skelett → PR) ──────────────────
# PAT mit contents:write + pull_requests:write auf JereIsThere/auge.
# Für Roadmaps (/api/roadmaps/github) zusätzlich contents:read auf ALLEN
# Ökosystem-Repos (gehirn, funkner sind private) — gleicher Token reicht,
# wenn der PAT repo-Scope hat oder als fine-grained PAT auf alle 4 Repos.
# Ohne Token: nur public Repos (auge, hand) sichtbar — gehirn+funkner fehlen.
GITHUB_TOKEN=
GITHUB_REPO=JereIsThere/auge

# ── SSH-Tunnel (optional) ──────────────────────────────────────────────
# Wenn SSH_HOST gesetzt ist, startet der Server vorher selbst
#   ssh -N -L <SSH_LOCAL_PORT>:<SSH_REMOTE_HOST>:<SSH_REMOTE_PORT> <SSH_USER>@<SSH_HOST>
# und beendet sich, wenn der Tunnel kippt. Voraussetzung: SSH-Key liegt
# beim Ziel-User (BatchMode=yes — kein Passwort-Prompt).
# Leer lassen wenn du den Tunnel selbst aufmachst oder OrientDB lokal läuft.
SSH_HOST=
SSH_USER=deploy
SSH_PORT=22
SSH_LOCAL_PORT=2480
SSH_REMOTE_HOST=localhost
SSH_REMOTE_PORT=2480
